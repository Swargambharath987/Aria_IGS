# ─────────────────────────────────────────────────────────────────────────────
# Aria IGS — Environment Configuration
# Copy this file to .env and fill in values. .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM — vLLM on IGS GPU server ─────────────────────────────────────────────
# Point at the vLLM server. Never use Ollama for the LLM.
LLM_BASE_URL=http://igs-gpu:8080/v1
LLM_MODEL=gemma4:e4b
LLM_API_KEY=not-needed
LLM_CONTEXT_WINDOW=32768

# ── Embeddings — Ollama (lightweight, stays local) ────────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434
EMBED_MODEL=nomic-embed-text

# ── Slurm SSH — IGS cluster access ───────────────────────────────────────────
SLURM_SSH_HOST=login.igs.umaryland.edu
SLURM_SSH_KEY_PATH=/run/secrets/slurm_key
SLURM_SSH_DEFAULT_USER=aria_service
SLURM_SSH_TIMEOUT=15

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-in-production
DEMO_USERS=admin:aria_demo,user1:aria_user
API_TOKENS=igs-dev-token

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_API_TOKEN=igs-dev-token
VITE_USER_ID=dev
